PORT=3001

# ── Hosted SaaS mode (accounts, billing, licensing) ─────────────────────────
# Leave APP_MODE unset (or 'local') for a single-tenant Electron/self-hosted
# install — none of the vars below are needed in that case.
# APP_MODE=hosted
# APP_URL=https://managram.uk
# DATABASE_URL=postgres://user:pass@host:5432/managram   # Railway Postgres add-on
#
# Generate with: node backend/scripts/generate-license-keys.js
# (writes the public half to electron/license-public-key.pem automatically —
# only the private key below needs to be set here, and never committed)
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
#
# Stripe — see https://dashboard.stripe.com/apikeys and /webhooks
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_ANNUAL=price_...

# ── Local mode (Electron / ngrok) ───────────────────────────────────────────
# These are stored in the SQLite DB after initial setup via the UI.
# You can also pre-populate them here if you prefer environment variables.
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=
# INSTAGRAM_USERNAME=
# CONTENT_FOLDER_PATH=C:/Users/YourName/Pictures/instagram
# OPENAI_API_KEY=sk-...
# PUBLIC_URL=https://your-ngrok-url.ngrok-free.app
# APP_ID=your_facebook_app_id
# APP_SECRET=your_facebook_app_secret

# ── R2 mode (Railway + Cloudflare R2) ───────────────────────────────────────
# Set all four R2 vars to enable R2 storage. The app auto-detects which mode
# to use based on whether R2_ACCOUNT_ID is present.
#
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=managram-media
#
# The public URL of your R2 bucket (set up via Cloudflare custom domain).
# Defaults to https://media.managram.uk if not set.
# R2_PUBLIC_URL=https://media.managram.uk
